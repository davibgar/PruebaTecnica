# Puerto del backend
PORT=3001

# Conexión a PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=nodotech
DB_PASSWORD=nodotech
DB_NAME=nodotech_marketing

# Origen permitido para CORS (frontend Next.js)
CORS_ORIGIN=http://localhost:3000

# Ventana de atribución por defecto (días)
ATTRIBUTION_WINDOW_DAYS=30

# Half-life del modelo time-decay (días)
ATTRIBUTION_HALF_LIFE_DAYS=7
